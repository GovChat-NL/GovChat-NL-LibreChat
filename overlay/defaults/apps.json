{
  "title": "App Launcher",
  "enabled": true,
  "chat_image_status": {
    "enabled": true,
    "first_message": "Afbeelding wordt gegenereerd. Dit duurt meestal 10–40 seconden.",
    "second_message": "Nog bezig met genereren. De afbeelding verschijnt hier zodra deze klaar is.",
    "second_delay_ms": 40000
  },
  "apps": [
    {
      "id": "chat",
      "name": "Chat",
      "icon": "💬",
      "description": "Terug naar de chatomgeving",
      "url": "/c/new",
      "target": "navigate"
    },
    {
      "id": "versimpelaar",
      "name": "Versimpelaar",
      "icon": "🔤",
      "description": "Vereenvoudig teksten naar B1 taalniveau",
      "url": "/n8n/webhook/versimpelaar",
      "target": "versimpelaar",
      "config": {
        "language_levels": ["B1"],
        "default_level": "B1",
        "webhook_token": "local_n8n_webhook_token_change_me"
      }
    },
    {
      "id": "afbeelding-generator",
      "name": "Afbeelding generator",
      "icon": "🖼️",
      "description": "Genereer afbeeldingen met voortgang en statusupdates",
      "url": "/govchat-api/image-jobs",
      "target": "imagegen",
      "config": {
        "image_jobs_api": "/govchat-api/image-jobs",
        "image_jobs_token": "local_image_jobs_token_change_me"
      }
    }
  ]
}

