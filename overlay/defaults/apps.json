{
  "title": "App Launcher",
  "enabled": true,
  "chat_image_status": {
    "enabled": true,
    "first_message": "Afbeelding wordt gegenereerd. Dit duurt meestal 10–40 seconden.",
    "second_message": "Nog bezig met genereren. De afbeelding verschijnt hier zodra deze klaar is.",
    "second_delay_ms": 40000
  },
  "apps": [
    {
      "id": "chat",
      "name": "Chat",
      "icon": "💬",
      "description": "Terug naar de chatomgeving",
      "url": "/c/new",
      "target": "navigate"
    },
    {
      "id": "versimpelaar",
      "name": "Versimpelaar",
      "icon": "🔤",
      "description": "Vereenvoudig teksten naar B1 taalniveau",
      "url": "/n8n/webhook/versimpelaar",
      "target": "versimpelaar",
      "config": {
        "language_levels": ["B1"],
        "default_level": "B1",
        "webhook_token": "local_n8n_webhook_token_change_me"
      }
    },
    {
      "id": "beleidskompas",
      "name": "Beleidskompas",
      "icon": "🧭",
      "description": "Ondersteuning bij beleidsafwegingen in vier stappen (SiS 4.0)",
      "url": "/c/new",
      "target": "beleidskompas",
      "config": {
        "specialist_team": "Bij hoge juridische/financiële impact: betrek concernjurist, financieel adviseur en programmaregisseur.",
        "sources": [
          "SiS 4.0 Strategisch kader",
          "SiS 4.0 Uitvoeringskader",
          "Provinciale Instrumentenkoffer",
          "Coalitieakkoord en beleidskaders",
          "Overzicht wettelijke taken Provincie"
        ]
      }
    },
    {
      "id": "afbeelding-generator",
      "name": "Afbeelding generator",
      "icon": "🖼️",
      "description": "Genereer afbeeldingen met voortgang en statusupdates",
      "url": "/govchat-api/image-jobs",
      "target": "imagegen",
      "config": {
        "image_jobs_api": "/govchat-api/image-jobs",
        "image_jobs_token": "local_image_jobs_token_change_me"
      }
    },
    {
      "id": "transcriptie",
      "name": "Live transcriptie",
      "icon": "🎙️",
      "description": "Live spraak-naar-tekst met slimme chunking (VAD, overlap, context)",
      "url": "/n8n/webhook/transcriptie-litellm",
      "target": "transcriptie",
      "config": {
        "webhook_token": "local_n8n_webhook_token_change_me",
        "chunk_ms": 5000,
        "chunk_min_ms": 2200,
        "chunk_max_ms": 20000,
        "vad_silence_ms": 900,
        "vad_threshold": 0.012,
        "silence_threshold": 0.012,
        "overlap_ms": 650,
        "context_prompt": "Nederlands gesprek, maak een complete en nette transcriptie.",
        "max_duration_minutes": 120,
        "litellm_model": "gpt-4o-transcribe",
        "realtime_enabled": false,
        "realtime_url": "/govchat-api/realtime-stt",
        "realtime_provider": "litellm",
        "realtime_model": "gpt-4o-realtime-preview",
        "realtime_commit_ms": 1200,
        "language": "nl",
        "title_webhook": "/n8n/webhook/transcriptie-title-litellm",
        "title_webhook_token": "local_n8n_webhook_token_change_me",
        "title_model": "govchat-default",
        "title_max_chars": 72,
        "title_timeout_ms": 6000,
        "enable_speaker_labels": false,
        "include_timestamps": true
      }
    }
  ]
}

